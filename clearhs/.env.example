# OpenAI (분류, RAG, 면세판단 등)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.5

# Upstage (PDF 추출)
UPSTAGE_API_KEY=up_xxxxxxxxxxxxx
UPSTAGE_MODEL=solar-pro2

# 비워두면 clearhs 폴더의 부모 폴더(프로젝트 루트)/chroma_db 를 기본값으로 사용
CHROMA_DB_PATH=

COLLECTION_NAME=customs_knowledge_v3
EMBEDDING_MODEL=BAAI/bge-m3

RETRIEVAL_WEIGHT=0.4
LLM_SELF_EVAL_WEIGHT=0.6